opt_out_usage

default_platform(:ios)

# Path constants
PROJECT         = "TextFriend.xcodeproj"
SCHEME          = "TextFriend"
APP_IDENTIFIER  = "com.cedricziel.textfriend"
OUTPUT_DIR      = "build"

# Build number = number of commits reachable from HEAD. Reproducible from git
# state alone — never committed back to project.yml.
def commit_count_build_number
  @commit_count_build_number ||= sh("git rev-list --count HEAD", log: false).strip
end

def archive_xcargs
  "CURRENT_PROJECT_VERSION=#{commit_count_build_number}"
end

before_all do |lane, options|
  Dotenv.load(".env") if File.exist?(".env")
  # Without setup_ci, codesign on macOS runners hangs forever waiting for
  # an interactive keychain unlock. setup_ci creates a temp keychain,
  # imports certs, and blesses the private key for non-interactive use.
  setup_ci if is_ci
  ensure_xcode_project_generated
end

# ---------------------------------------------------------------------------
# Public lanes
# ---------------------------------------------------------------------------

desc "Run all unit tests on the iOS simulator"
lane :test do
  run_tests(
    project: PROJECT,
    scheme: SCHEME,
    devices: [ENV["SIMULATOR"] || "iPhone 17 Pro"],
    clean: false,
    output_directory: "fastlane/test_output"
  )
end

desc "Build the app for release without uploading (sanity check)"
lane :build do
  api_key = load_app_store_connect_api_key
  sync_code_signing(type: "appstore", readonly: is_ci, api_key: api_key)

  build_app(
    project: PROJECT,
    scheme: SCHEME,
    configuration: "Release",
    export_method: "app-store",
    output_directory: OUTPUT_DIR,
    output_name: "TextFriend.ipa",
    clean: true,
    include_symbols: true,
    include_bitcode: false,
    destination: "generic/platform=iOS",
    xcargs: archive_xcargs
  )
end

desc "Push a new beta build to TestFlight"
lane :beta do |options|
  api_key = load_app_store_connect_api_key
  ensure_git_status_clean unless options[:allow_dirty]

  # xcodebuild archive resolves dev profiles for some intermediate build
  # phases even when configuration:Release. Sync both so the keychain has
  # everything available; final signing still uses the appstore profile.
  sync_code_signing(type: "development", readonly: is_ci, api_key: api_key)
  sync_code_signing(type: "appstore",    readonly: is_ci, api_key: api_key)

  build_app(
    project: PROJECT,
    scheme: SCHEME,
    configuration: "Release",
    export_method: "app-store",
    output_directory: OUTPUT_DIR,
    output_name: "TextFriend.ipa",
    clean: true,
    include_symbols: true,
    include_bitcode: false,
    destination: "generic/platform=iOS",
    xcargs: archive_xcargs
  )

  upload_to_testflight(
    api_key: api_key,
    app_identifier: APP_IDENTIFIER,
    skip_waiting_for_build_processing: true,
    changelog: options[:changelog] || "Beta build #{Time.now.strftime('%Y-%m-%d %H:%M')}"
  )
  # dSYMs are bundled in the IPA via build_app's include_symbols:true and
  # App Store Connect extracts them automatically — no separate upload step.
end

desc "Submit an existing TestFlight build to App Store review without rebuilding"
lane :submit_to_app_store do |options|
  api_key = load_app_store_connect_api_key
  stage_release_notes!(options[:release_notes] || ENV["RELEASE_NOTES"])

  upload_to_app_store(
    api_key: api_key,
    app_identifier: APP_IDENTIFIER,
    app_version: options[:version],
    skip_binary_upload: true,
    submit_for_review: options[:submit] != false,
    automatic_release: options[:auto_release] == true,
    force: true,
    precheck_include_in_app_purchases: false,
    skip_screenshots: true,
    skip_metadata: options[:metadata] == false,
    build_number: options[:build],
    app_rating_config_path: "fastlane/metadata/age_rating.json",
    submission_information: {
      add_id_info_uses_idfa: false,
      content_rights_contains_third_party_content: false,
    }
  )
end

desc "Upload App Store metadata (description, keywords, release notes, ...) without touching the binary"
lane :sync_metadata do |options|
  api_key = load_app_store_connect_api_key
  stage_release_notes!(options[:release_notes] || ENV["RELEASE_NOTES"])

  upload_to_app_store(
    api_key: api_key,
    app_identifier: APP_IDENTIFIER,
    skip_binary_upload: true,
    skip_screenshots: true,
    skip_metadata: false,
    submit_for_review: false,
    automatic_release: false,
    force: true,
    precheck_include_in_app_purchases: false,
    run_precheck_before_submit: false
  )
end

desc "Generate App Store screenshots via the ScreenshotTests UI test"
lane :screenshots do
  capture_ios_screenshots
end

desc "Upload screenshots to App Store Connect"
lane :sync_screenshots do
  api_key = load_app_store_connect_api_key
  upload_to_app_store(
    api_key: api_key,
    app_identifier: APP_IDENTIFIER,
    skip_binary_upload: true,
    skip_metadata: true,
    skip_screenshots: false,
    overwrite_screenshots: true,
    submit_for_review: false,
    force: true,
    precheck_include_in_app_purchases: false,
    run_precheck_before_submit: false
  )
end

desc "Upload the App Privacy nutrition label (data not collected)"
lane :sync_privacy do
  api_key = load_app_store_connect_api_key
  # The action has no api_key option; it reuses the Spaceship token that
  # load_app_store_connect_api_key already installed.
  _ = api_key
  upload_app_privacy_details_to_app_store(
    app_identifier: APP_IDENTIFIER,
    json_path: "fastlane/app_privacy_details.json"
  )
end

desc "Sync signing certificates and provisioning profiles via match"
lane :sync_signing do |options|
  type = options[:type] || "development"
  api_key = load_app_store_connect_api_key
  match(type: type, readonly: options[:readonly] != false, api_key: api_key)
end

desc "Bootstrap signing — creates new certs/profiles. Run once per environment."
lane :bootstrap_signing do
  api_key = load_app_store_connect_api_key
  match(type: "development", readonly: false, api_key: api_key)
  match(type: "appstore",    readonly: false, api_key: api_key)
end

desc "Print the build number that would be used (commit count from HEAD)"
lane :show_build_number do
  UI.message("Build number: #{commit_count_build_number}")
end

# ---------------------------------------------------------------------------
# Private helpers
# ---------------------------------------------------------------------------

desc "Regenerate the Xcode project from project.yml when missing"
private_lane :ensure_xcode_project_generated do
  unless File.exist?("../#{PROJECT}/project.pbxproj")
    UI.message("Generating Xcode project via xcodegen...")
    sh "cd .. && xcodegen generate"
  end
end

# Stages release notes into fastlane/metadata/<locale>/release_notes.txt so
# upload_to_app_store picks them up. No-op when the input is nil/empty so a
# previously committed release_notes.txt remains the source of truth.
def stage_release_notes!(notes, locale: "en-US")
  return if notes.nil? || notes.to_s.strip.empty?

  dir = File.expand_path("metadata/#{locale}", __dir__)
  FileUtils.mkdir_p(dir)
  path = File.join(dir, "release_notes.txt")
  File.write(path, notes.to_s.strip + "\n")
  UI.message("Staged release notes (#{notes.to_s.strip.bytesize} bytes) at #{path}")
end

# Loads an App Store Connect API key from one of:
#   - ASC_KEY_PATH        : filesystem path to the .p8 file
#   - ASC_KEY_CONTENT     : raw or base64-encoded contents of the .p8 file
#
# Required env vars: ASC_KEY_ID, ASC_ISSUER_ID
def load_app_store_connect_api_key
  return @asc_api_key if @asc_api_key

  # fastlane auto-loads fastlane/.env.default, whose placeholder entries
  # yield empty strings — treat those as unset.
  env = ->(name) {
    value = ENV[name]
    value.nil? || value.strip.empty? ? nil : value
  }
  key_id      = env.call("ASC_KEY_ID")
  issuer_id   = env.call("ASC_ISSUER_ID")
  key_path    = env.call("ASC_KEY_PATH")
  key_content = env.call("ASC_KEY_CONTENT")

  if key_id.nil? || issuer_id.nil? || (key_path.nil? && key_content.nil?)
    UI.user_error!(<<~MSG)
      Missing App Store Connect API key configuration. Set:
        ASC_KEY_ID         (e.g. ABC123XYZ9)
        ASC_ISSUER_ID      (UUID from appstoreconnect.apple.com -> Users and Access -> Keys)
        ASC_KEY_PATH       (path to .p8 file)  OR  ASC_KEY_CONTENT (raw or base64)

      Locally: copy fastlane/.env.default to fastlane/.env and fill in.
      In CI:   configure these as GitHub Actions secrets.
    MSG
  end

  # fastlane >= 2.235 rejects key_filepath and key_content together,
  # even when one of them is nil — pass exactly one.
  params = { key_id: key_id, issuer_id: issuer_id, in_house: false }
  if key_path
    params[:key_filepath] = key_path
  else
    params[:key_content] = key_content
    params[:is_key_content_base64] =
      key_content.match?(/\A[A-Za-z0-9+\/=\s]+\z/) && !key_content.include?("BEGIN PRIVATE KEY")
  end
  @asc_api_key = app_store_connect_api_key(**params)
end

error do |lane, exception|
  UI.error("Lane #{lane} failed: #{exception.message}")
end
