# Copy to fastlane/.env and fill in. fastlane/.env is gitignored.
#
# NOTE: fastlane auto-loads this file, so real keys stay commented out —
# uncomment them only in your local .env copy.
#
# Values live in 1Password:
#   ASC_KEY_ID / ASC_ISSUER_ID / .p8 file -> "AppStore Connect: fastlane-ci"
#   MATCH_PASSWORD                        -> "fastlane-ci: match"
#
# Example for local use with the 1Password CLI:
#   ASC_KEY_ID=$(op item get "AppStore Connect: fastlane-ci" --fields Benutzername)
#   MATCH_PASSWORD=$(op item get "fastlane-ci: match" --fields password --reveal)

# ASC_KEY_ID=
# ASC_ISSUER_ID=
# Either a path to the .p8 ...
# ASC_KEY_PATH=
# ... or its (optionally base64-encoded) content.
# ASC_KEY_CONTENT=

# MATCH_GIT_URL=git@github.com:cedricziel/certificates.git
# MATCH_PASSWORD=
